# Solana RPC endpoint (use a private RPC in production)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Anchor program ID deployed on Devnet
PROGRAM_ID=your_program_id_here

# Public vars for frontend wallet adapter (safe to expose)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=your_program_id_here

# Public key of the event creator wallet (receives ticket payments)
EVENT_AUTHORITY=your_event_creator_pubkey_here

# Event configuration
EVENT_ID=1
EVENT_NAME=My Event Name
EVENT_DESCRIPTION=Event description here
EVENT_TICKET_PRICE_SOL=0.05
EVENT_MAX_TICKETS=100
EVENT_IMAGE_URL=https://example.com/image.png
EVENT_TYPE=0

# Relay keypair for gasless transactions (JSON array of secret key bytes)
# Generate with: solana-keygen new --no-bip39-passphrase -o relay.json
# Then: cat relay.json  (paste the full array here)
RELAY_PRIVATE_KEY=[paste_your_relay_keypair_bytes_here]
